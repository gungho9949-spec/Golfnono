{
  "rewrites": [
    { "source": "/api/courses", "destination": "/api/courses.js" },
    { "source": "/api/cctv", "destination": "/api/cctv.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "s-maxage=86400" }
      ]
    }
  ],
  "functions": {
    "api/its-cctv.js": {
      "maxDuration": 10
    },
    "api/stream.js": {
      "maxDuration": 15
    }
  }
}
